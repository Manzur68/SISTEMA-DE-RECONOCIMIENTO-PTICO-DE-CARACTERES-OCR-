pipeline {
    agent none

    environment {
        DOCKER_HOST                  = 'unix:///var/run/docker.sock'
        TESTCONTAINERS_RYUK_DISABLED = 'true'
        API_URL                      = 'http://localhost:8000'
    }

    options {
        timeout(time: 30, unit: 'MINUTES')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Checkout') {
            agent { label 'built-in' }
            steps {
                echo '📥 Obteniendo código fuente...'
                checkout scm
                sh 'echo "Rama   : $(git branch --show-current)"'
                sh 'echo "Commit : $(git log --oneline -1)"'
            }
        }
        stage('Tests VM1 — Unitarios + Integración') {
	    agent { label 'built-in' }
	    steps {
		echo '[VM1] Ejecutando tests de api_gateway, ms_calificacion, ms_reporte...'
		dir('vm1') {
		    sh '''
		        # Crear venv si no existe
		        if [ ! -d /tmp/venv-vm1 ]; then
		            python3 -m venv /tmp/venv-vm1
		        fi

		        # Activar venv
		        . /tmp/venv-vm1/bin/activate

		        # Instalar dependencias
		        pip install -r tests/requirements-test.txt \
		            --prefer-binary --quiet

		        # Ejecutar tests
		        python -m pytest tests/test_suite.py \
		            -v \
		            --timeout=120 \
		            --tb=short \
		            --junitxml=test-results-vm1.xml \
		            -p no:warnings

		        deactivate
		    '''
		}
	    }
	    post {
		always {
		    junit allowEmptyResults: true,
		          testResults: 'vm1/test-results-vm1.xml'
		}
		success { echo 'Tests VM1 pasaron' }
		failure { echo 'Tests VM1 fallaron' }
	    }
	}

        stage('Tests VM2 — Unitarios + Integración OCR') {
            agent { label 'vm2-agent' }
            steps {
                echo '[VM2] Ejecutando tests de ms_preprocesamiento y ms_ocr...'
                sh '''
                    export PATH="$HOME/.local/bin:$PATH"

                    # Activar el entorno virtual creado por setup-agent-vm2.sh
                    source ~/venv-jenkins/bin/activate

                    # Actualizar dependencias si cambiaron
                    pip install -r vm2/tests/requirements-test.txt \
                        --prefer-binary \
                        --quiet

                    # Ejecutar tests desde la raíz del workspace
                    python -m pytest vm2/tests/test_suite.py \
                        -v \
                        --timeout=120 \
                        --tb=short \
                        --junitxml=test-results-vm2.xml \
                        -p no:warnings

                    deactivate
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'test-results-vm2.xml'
                }
                success { echo 'Tests VM2 pasaron' }
                failure { echo 'Tests VM2 fallaron' }
            }
        }

        stage('Deploy VM1') {
            agent { label 'built-in' }
            when { branch 'main' }
            steps {
                echo '[VM1] Desplegando api_gateway, ms_calificacion, ms_reporte...'
                dir('vm1') {
                    sh '''
                        if [ ! -f .env.vm1 ]; then
                            echo "ERROR: Falta el archivo vm1/.env.vm1"
                            exit 1
                        fi

                        docker compose -f docker-compose.vm1.yml \
                            --env-file .env.vm1 \
                            up -d --build

                        echo "Esperando 20s para que los servicios inicien..."
                        sleep 20

                        docker compose -f docker-compose.vm1.yml ps
                    '''
                }
            }
            post {
                success { echo 'VM1 desplegada correctamente' }
                failure {
                    sh '''
                        echo "Logs de VM1:"
                        docker compose -f vm1/docker-compose.vm1.yml \
                            logs --tail=30 || true
                    '''
                }
            }
        }

        stage('Deploy VM2') {
            agent { label 'vm2-agent' }
            when { branch 'main' }
            steps {
                echo '[VM2] Desplegando ms_preprocesamiento y ms_ocr...'
                dir('vm2') {
                    sh '''
                        if [ ! -f .env.vm2 ]; then
                            echo "ERROR: Falta el archivo vm2/.env.vm2"
                            echo "Creando .env.vm2 desde .env.vm2.example..."
                            cp .env.vm2.example .env.vm2
                            echo "Edita vm2/.env.vm2 con la IP real de VM1"
                        fi

                        docker compose -f docker-compose.vm2.yml \
                            --env-file .env.vm2 \
                            up -d --build

                        echo "Esperando 10s..."
                        sleep 10

                        docker compose -f docker-compose.vm2.yml ps
                    '''
                }
            }
            post {
                success { echo 'VM2 desplegada correctamente' }
                failure {
                    sh '''
                        echo "Logs de VM2:"
                        docker compose -f vm2/docker-compose.vm2.yml \
                            logs --tail=30 || true
                    '''
                }
            }
        }

        stage('Tests E2E — Sistema Real') {
            agent { label 'built-in' }
            when { branch 'main' }
            steps {
                echo '[VM1] Ejecutando tests E2E contra el sistema desplegado...'
                sh '''
                    export PATH="$HOME/.local/bin:$PATH"

                    pip3 install -r e2e/requirements-e2e.txt \
                        --prefer-binary \
                        --break-system-packages \
                        --quiet

                    API_URL=http://localhost:8000 \
                    python3 -m pytest e2e/test_e2e.py \
                        -v \
                        --timeout=90 \
                        --tb=short \
                        --junitxml=test-results-e2e.xml \
                        -p no:warnings
                '''
            }
            post {
                always {
                    junit allowEmptyResults: true,
                          testResults: 'test-results-e2e.xml'
                }
                success { echo 'Tests E2E pasaron — sistema operativo' }
                failure {
                    sh '''
                        echo "Health check del sistema:"
                        curl -s http://localhost:8000/health || echo "API no responde"
                        echo "Contenedores corriendo:"
                        docker ps || true
                    '''
                }
            }
        }

    } // end stages

    post {
        success {
            node('built-in') {
                echo '''
╔══════════════════════════════════════════════╗
║    Pipeline completado exitosamente          ║
║     Todos los tests pasaron                  ║
║     VM1 y VM2 desplegadas y operativas       ║
╚══════════════════════════════════════════════╝
                '''
            }
        }
        failure {
            node('built-in') {
                echo '''
╔══════════════════════════════════════════════╗
║    Pipeline FALLÓ                            ║
║     Revisar los logs de cada stage           ║
╚══════════════════════════════════════════════╝
                '''
            }
        }
        always {
            node('built-in') {
                sh 'docker container prune -f 2>/dev/null || true'
                echo 'Pipeline finalizado.'
            }
        }
    }
}
